# ──────────────────────────────────────────────────────────
# SARAS ERP v2 — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# These are baked into the client bundle at build time (VITE_ prefix).

# Supabase project URL
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# Format: https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://kcnujpvzewtuttfcrtyz.supabase.co

# Supabase anonymous (public) key — safe for client-side use
# Get from: same settings page → anon / public key
# Format: eyJ... (long JWT)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
