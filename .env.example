# SARAS ERP v2 — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is in .gitignore.

# Supabase — get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Optional: WhatsApp/Slack webhook for notifications (leave empty to disable)
VITE_NOTIFICATION_WEBHOOK_URL=

# E2E tests — Playwright only (not runtime)
# BASE_URL=https://saras-erp-v2-rebuild.vercel.app
# TEST_EMAIL=your-test-email@example.com
# TEST_PASSWORD=your-test-password
